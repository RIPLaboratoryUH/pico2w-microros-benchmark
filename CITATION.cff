    given-names: Mark
    affiliation: "Department of Engineering, University of Hawaiʻi"
    email: markcia@hawaii.edu
license: MIT
repository-code: "https://github.com/RIPLaboratoryUH/pico2w-microros-benchmark"
keywords:
  - micro-ROS
  - ROS 2
  - Raspberry Pi Pico 2W
  - embedded systems
  - wireless communication
  - latency benchmarking
